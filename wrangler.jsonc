{
  // Cloudflare Worker config for Fervent Digital Marketing
  // This file tells Cloudflare which files in the repo to deploy as the live site.
  // Edit "name" only if you rename the Worker in the Cloudflare dashboard.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fervent-digital",
  "compatibility_date": "2026-05-04",
  "assets": {
    "directory": "./",
    "not_found_handling": "404-page"
  }
}
